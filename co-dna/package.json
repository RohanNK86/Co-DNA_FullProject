{
  "name": "co-dna",
  "displayName": "Co-DNA",
  "description": "Co-DNA is an AI-powered VS Code extension that identifies, quantifies, and visualizes technical debt in real time.It analyzes code complexity, structure, and patterns to generate a  Score, flowcharts, and actionable insights.Developers can instantly understand messy code and follow a prioritized roadmap to improve quality and reduce maintenance cost.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codnaView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Co-DNA",
      "properties": {
        "co-dna.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "DebtSight backend base URL (no trailing slash). Same as Postman, e.g. https://your-app.onrender.com"
        }
      }
    },
    "commands": [
      {
        "command": "co-dna.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "co-dna.analyzeCurrentFile",
        "title": "Co-DNA: Analyze current file",
        "category": "Co-DNA"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codna-sidebar",
          "title": "Co-DNA",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codna-sidebar": [
        {
          "id": "codnaView",
          "name": "Technical Debt",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "node ./node_modules/typescript/lib/tsc.js --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "node ./node_modules/typescript/lib/tsc.js -p . --outDir out",
    "watch-tests": "node ./node_modules/typescript/lib/tsc.js -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "lint": "node ./node_modules/eslint/bin/eslint.js src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "diff": "8.0.4",
    "serialize-javascript": "7.0.5"
  }
}
