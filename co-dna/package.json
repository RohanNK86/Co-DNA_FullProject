{
  "name": "co-dna",
  "displayName": "Co-DNA 1.2",
  "description": "DebtSight-powered technical debt analyzer: complexity, security, dependencies, tests, Mermaid diagrams, and prioritized remediation — wired to your DebtSight Node.js backend.",
  "version": "1.2.0",
  "publisher": "debtsight",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "technical debt",
    "security",
    "refactor",
    "DebtSight",
    "AI",
    "mermaid"
  ],
  "activationEvents": [
    "onCommand:co-dna.analyzeDebt",
    "onCommand:co-dna.explainCode",
    "onCommand:co-dna.modernizeCode",
    "onCommand:co-dna.rewriteCodebase"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Co-DNA 1.2 (DebtSight)",
      "properties": {
        "co-dna.apiBaseUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Single DebtSight backend base URL (no trailing slash). e.g. https://your-app.onrender.com"
        },
        "co-dna.modelLabel": {
          "type": "string",
          "default": "Gemini · DebtSight",
          "description": "Shown in the analysis panel header (matches your backend AI)."
        }
      }
    },
    "commands": [
      {
        "command": "co-dna.analyzeDebt",
        "title": "Co-DNA 1.2: Analyze Technical Debt (DebtSight)",
        "category": "DebtSight"
      },
      {
        "command": "co-dna.explainCode",
        "title": "Co-DNA 1.2: Explain Code",
        "category": "DebtSight"
      },
      {
        "command": "co-dna.modernizeCode",
        "title": "Co-DNA 1.2: Modernize Code",
        "category": "DebtSight"
      },
      {
        "command": "co-dna.rewriteCodebase",
        "title": "Co-DNA 1.2: Rewrite Codebase (AI)",
        "category": "DebtSight"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "co-dna.analyzeDebt",
          "group": "navigation@1",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
